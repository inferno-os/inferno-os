#!/dis/sh.dis
# InferNode shell initialization
load std

# Set command search path
path=(/dis .)

# Get username
user="{cat /dev/user}

# ── Networking ──────────────────────────────────────────────
mount -ac {mntgen} /n >[2] /dev/null
bind -a '#I' /net >[2] /dev/null
ndb/cs

# ── Host filesystem + home directory (early — needed for overlays) ──
if {~ $emuhost MacOSX Linux}{
	trfs '#U*' /n/local >[2] /dev/null
	ghome=/n/local/^`{echo 'echo $HOME' | os sh}
	home=$ghome
}{
	# Non-desktop platforms (native hardware, embedded)
	home=/usr/^$user
	if {! ftest -d $home} { mkdir -p $home }
}

# ── Writable overlay from ~/.inferno (bundle mode only) ────
# The .bundle sentinel is created by the release workflow.
# Dev checkouts don't have it — the overlay block is skipped entirely.
bundlemode=no
if {ftest -f /lib/lucifer/.bundle} {
	bundlemode=yes
	infhome=$ghome^/.inferno

	# First-run: create overlay structure and seed defaults.
	# Everything happens on the host side via 'os sh' — Inferno's cp
	# through trfs to newly-created dirs fails silently.
	# $emuroot is the host path to the Inferno root (set by emu).
	if {! ftest -d $infhome} {
		os sh -c 'mkdir -p "$HOME/.inferno/usr/inferno/secstore"'
		os sh -c 'mkdir -p "$HOME/.inferno/usr/inferno/tmp"'
		os sh -c 'mkdir -p "$HOME/.inferno/lib/ndb"'
		os sh -c 'mkdir -p "$HOME/.inferno/lib/lucifer/theme"'
		os sh -c 'mkdir -p "$HOME/.inferno/lib/veltro"'
		os sh -c 'mkdir -p "$HOME/.inferno/lib/veltro-agents"'
		os sh -c 'mkdir -p "$HOME/.inferno/lib/veltro-keys"'
		os sh -c 'mkdir -p "$HOME/.inferno/tmp"'
		# Seed writable defaults from the bundle on the host side.
		# $emuroot is the host path to the emu root (bundle Resources/).
		eroot=$emuroot
		os sh -c 'cp "'^$eroot^'/lib/ndb/llm" "$HOME/.inferno/lib/ndb/" 2>/dev/null'
		os sh -c 'cp "'^$eroot^'/lib/lucifer/theme/current" "$HOME/.inferno/lib/lucifer/theme/" 2>/dev/null'
		os sh -c 'cp "'^$eroot^'/lib/veltro/meta.txt" "$HOME/.inferno/lib/veltro/" 2>/dev/null'
		os sh -c 'cp "'^$eroot^'/lib/veltro/agents/task.txt" "$HOME/.inferno/lib/veltro-agents/" 2>/dev/null'
	}

	# Writable overlay mounts.
	# Note: bind -c (MREPL) silently fails with trfs-backed sources.
	# Use bind -bc (MBEFORE|MCREATE) — overlay files shadow the bundle's
	# empty dirs, and new files are created in the writable overlay.
	bind -bc $infhome/usr/inferno/secstore /usr/inferno/secstore
	bind -bc $infhome/usr/inferno/tmp      /usr/inferno/tmp

	# Union overlays — writable files shadow bundle defaults,
	# bundle-only files (system.txt, tools/, policies/) show through.
	bind -bc $infhome/lib/ndb              /lib/ndb
	bind -bc $infhome/lib/lucifer/theme    /lib/lucifer/theme

	# Veltro top-level: meta.txt, welcome_shown, tour_offered shadow bundle.
	# No agents/ or keys/ subdirs in overlay, so bundle's show through.
	bind -bc $infhome/lib/veltro           /lib/veltro
	# Separate union for agents (task.txt writable, others from bundle)
	bind -bc $infhome/lib/veltro-agents    /lib/veltro/agents
	# Separate union for keys (all writable)
	bind -bc $infhome/lib/veltro-keys      /lib/veltro/keys >[2] /dev/null

	# Writable /tmp
	bind -bc $infhome/tmp /tmp >[2] /dev/null
}

# ── Secstored (persistent encrypted key storage) ──────────
# Kill stale secstored from a previous emu session — a stale
# instance with different PAK data causes login to hang indefinitely.
os sh -c 'lsof -ti :5356 2>/dev/null | xargs kill 2>/dev/null; sleep 1; true' >[2] /dev/null
mkdir -p /usr/inferno/secstore >[2] /dev/null
auth/secstored >[2] /dev/null &
sleep 1

# ── Factotum ──────────────────────────────────────────────
# Headless: if $SECSTORE_PASSWORD is set on the host, start factotum
# with secstore backing so all keys are loaded automatically.
# GUI: factotum starts empty; wm/logon unlocks secstore interactively.
if {! ftest -f /mnt/factotum/proto}{
	havesecpass=`{os sh -c 'if [ -n "$SECSTORE_PASSWORD" ]; then echo yes; fi' >[2] /dev/null}
	if {~ $havesecpass yes} {
		secpass=`{os sh -c 'printf "%s" "$SECSTORE_PASSWORD"'}
		auth/factotum -S tcp!localhost!5356 -P $secpass
	}{
		auth/factotum
	}
}

# Provision API key from host env (fallback for CLI users without secstore)
factotumkey=`{os sh -c 'if [ -n "$ANTHROPIC_API_KEY" ]; then echo "key proto=pass service=anthropic user=apikey !password=$ANTHROPIC_API_KEY"; fi'}
echo $factotumkey > /mnt/factotum/ctl >[2] /dev/null

# ── LLM + Speech (desktop platforms) ──────────────────────
if {~ $emuhost MacOSX Linux}{
	llmmode=`{sed -n 's/^mode=//p' /lib/ndb/llm >[2] /dev/null}
	if {~ $llmmode remote} {
		llmdial=`{sed -n 's/^dial=//p' /lib/ndb/llm}
		mount -A $llmdial /n/llm >[2] /dev/null
	}{
		llmsrv >[2] /dev/null &
	}

	# Start speech file server (TTS/STT via /n/speech)
	/dis/veltro/speech9p.dis -e cmd &
}{
	# Non-desktop: mount remote llm9p
	mount -A 'tcp!llmserver!5640' /n/llm >[2] /dev/null
}

# ── tmp setup ─────────────────────────────────────────────
if {! ftest -d $home/tmp} {
	mkdir -p $home/tmp
}
mkdir -p /tmp >[2] /dev/null
# In dev mode, bind home tmp to /tmp. In bundle mode, overlay already
# provides a writable /tmp, so layer home tmp on top of it.
bind -bc $home/tmp /tmp >[2] /dev/null

# Clean stale temp files from previous sessions
for f in /tmp/*.????xenith /tmp/*.????acme /tmp/*.????blks {
	rm $f >[2] /dev/null
}

cd $home
