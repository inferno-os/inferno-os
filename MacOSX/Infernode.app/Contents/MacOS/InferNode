#!/bin/sh

# Get the directory containing this script (Contents/MacOS)
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Navigate to InferNode root (MacOSX/InferNode.app/Contents/MacOS -> root)
INFERNODE_ROOT="$(cd "$SCRIPT_DIR/../../../.." && pwd)"

EMU="$INFERNODE_ROOT/emu/MacOSX/o.emu"

# Login screen unlocks secstore/factotum, then wallet9p starts (needs keys).
# The -b flag sets the budget of tools delegatable to child task agents.
LUCIFER_CMD='wm/logon; /dis/veltro/wallet9p.dis &; sleep 1; luciuisrv; echo activity create Main > /n/ui/ctl; sleep 1; /dis/veltro/tools9p -v -m /tool -b read,list,find,search,grep,write,edit,exec,launch,spawn,diff,json,webfetch,git,memory,todo,plan,websearch,mail,keyring,present,gap -p /dis/wm read list find present say hear task memory gap keyring editor shell; lucibridge -a 0 -v -s &; sleep 1; echo '"'"'create id=tasks type=taskboard label=Tasks'"'"' > /n/ui/activity/0/presentation/ctl; lucifer'

# --- Launch emulator ---
# LLM service (local llmsrv or remote 9P mount) is configured in lib/sh/profile
# and managed via the Settings app. The profile runs on "sh -l" before LUCIFER_CMD.
cd "$INFERNODE_ROOT/emu/MacOSX"
echo brimstone > "$INFERNODE_ROOT/lib/lucifer/theme/current"

exec "$EMU" -c1 -pheap=1024m -pmain=1024m -pimage=1024m -r../.. sh -l -c "$LUCIFER_CMD"
