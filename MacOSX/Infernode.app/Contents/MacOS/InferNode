#!/bin/sh

# InferNode.app launcher
# The bundle root (Contents/Resources/) is read-only. The profile sets up
# writable overlays from ~/.inferno for secstore, config, and tmp.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BUNDLE_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
RESOURCES="$BUNDLE_DIR/Resources"

# Refuse to run from a DMG or App Translocation sandbox.
case "$SCRIPT_DIR" in
    /Volumes/*|*/AppTranslocation/*)
        osascript -e 'display dialog "InferNode cannot run from a disk image. Please copy InferNode.app to your hard drive first (e.g. Applications, Desktop, or any folder)." buttons {"OK"} default button "OK" with title "InferNode" with icon caution' 2>/dev/null
        exit 0
        ;;
esac

EMU="$SCRIPT_DIR/emu"

# Launch: profile (-l) sets up overlays, then boot.sh starts the GUI.
exec "$EMU" -c1 "-pheap=1024m" "-pmain=1024m" "-pimage=1024m" "-r$RESOURCES" sh -l /lib/lucifer/boot.sh
