# SDL3 GUI backend for Linux
# Cross-platform GUI with GPU acceleration (Vulkan/OpenGL on Linux)
#
# Variable definitions only - build rule is in the main mkfile
# to avoid overriding the default target.

GUISRC=\
	draw-sdl3.$O\

# SDL3 configuration
# Install with: sudo apt install libsdl3-dev (or ./install-sdl3.sh)
SDL3_CFLAGS=-I/usr/local/include
SDL3_LIBS=-L/usr/local/lib -lSDL3

GUIFLAGS=-DGUI_SDL3 $SDL3_CFLAGS
GUILIBS=$SDL3_LIBS
