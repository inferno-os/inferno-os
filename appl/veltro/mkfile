    agentlib.dis\
    veltro.dis\
    repl.dis\
    tools9p.dis\
    nsconstruct.dis\
    cowfs.dis\
    subagent.dis\
    mc9p.dis\
    speech9p.dis\
    msg9p.dis\
    msgwatch.dis\

