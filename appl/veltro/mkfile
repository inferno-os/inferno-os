install:V: all
	mkdir -p $DISBIN $DISBIN/tools $DISBIN/sources
	cp agentlib.dis veltro.dis repl.dis tools9p.dis nsconstruct.dis cowfs.dis subagent.dis mc9p.dis speech9p.dis msg9p.dis msgwatch.dis $DISBIN/
	cp tools/*.dis $DISBIN/tools/
	cp sources/*.dis $DISBIN/sources/

clean:V:
	rm -f *.dis *.sbl tools/*.dis tools/*.sbl sources/*.dis sources/*.sbl

nuke:V: clean
	rm -rf $DISBIN
