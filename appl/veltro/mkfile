    sources/email.dis\

TOOLS=\
    tools/read.dis\
    tools/list.dis\
    tools/find.dis\
    tools/search.dis\
    tools/write.dis\
    tools/edit.dis\
    tools/exec.dis\
	tools/launch.dis\
    tools/spawn.dis\
    tools/safeexec.dis\
    tools/xenith.dis\
    tools/editor.dis\
    tools/shell.dis\
